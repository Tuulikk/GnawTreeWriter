{
  "name": "gnawtreewriter-mcp",
  "publisher": "GnawSoftware",
  "displayName": "GnawTreeWriter MCP",
  "description": "Registers GnawTreeWriter as an MCP server for Copilot — surgical AST-based code editing via mcp_gnawtreewrite_* tools.",
  "version": "0.1.0",
  "private": true,
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tuulikk/GnawTreeWriter.git"
  },
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "gnawtreewriter",
    "ast",
    "mcp",
    "code-editing",
    "gnaw"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "gnaw-software.gnawtreewriter.mcp",
        "label": "GnawTreeWriter MCP"
      }
    ],
    "configuration": {
      "title": "GnawTreeWriter",
      "properties": {
        "gnawtreewriter.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Path to gnawtreewriter binary. Supports ${userHome} and ${env:VAR}. Leave empty to auto-detect (checks PATH, ~/.cargo/bin/)."
        }
      }
    }
  }
}
